{
  "$description": "Mosaic design tokens (W3C DTCG format). These are the neutral placeholder values the Mosaic Design Language will replace. A generator compiles them to the Shell's CSS variables and to a Flutter ThemeData. This file holds the dark theme; the light theme and the generator are the next slice.",
  "color": {
    "bg": { "$type": "color", "$value": "#0b0d12" },
    "surface": { "$type": "color", "$value": "#14171f" },
    "surface-raised": { "$type": "color", "$value": "#1b1f2a" },
    "surface-overlay": { "$type": "color", "$value": "#222735" },
    "text": { "$type": "color", "$value": "#eef1f7" },
    "text-muted": { "$type": "color", "$value": "#a4adbe" },
    "text-faint": { "$type": "color", "$value": "#6b7386" },
    "text-on-accent": { "$type": "color", "$value": "#0b0d12" },
    "accent": { "$type": "color", "$value": "#5b8cff" },
    "accent-hover": { "$type": "color", "$value": "#7aa2ff" },
    "success": { "$type": "color", "$value": "#3fbf7f" },
    "warning": { "$type": "color", "$value": "#e6b055" },
    "danger": { "$type": "color", "$value": "#ef5f6b" },
    "info": { "$type": "color", "$value": "#5b8cff" },
    "rating": { "$type": "color", "$value": "#ffc857" }
  },
  "space": {
    "1": { "$type": "dimension", "$value": "4px" },
    "2": { "$type": "dimension", "$value": "8px" },
    "3": { "$type": "dimension", "$value": "12px" },
    "4": { "$type": "dimension", "$value": "16px" },
    "5": { "$type": "dimension", "$value": "24px" },
    "6": { "$type": "dimension", "$value": "32px" },
    "7": { "$type": "dimension", "$value": "48px" },
    "8": { "$type": "dimension", "$value": "64px" }
  },
  "radius": {
    "sm": { "$type": "dimension", "$value": "6px" },
    "md": { "$type": "dimension", "$value": "10px" },
    "lg": { "$type": "dimension", "$value": "16px" },
    "xl": { "$type": "dimension", "$value": "22px" },
    "pill": { "$type": "dimension", "$value": "999px" }
  },
  "text": {
    "xs": { "$type": "dimension", "$value": "0.75rem" },
    "sm": { "$type": "dimension", "$value": "0.85rem" },
    "md": { "$type": "dimension", "$value": "0.95rem" },
    "lg": { "$type": "dimension", "$value": "1.15rem" },
    "xl": { "$type": "dimension", "$value": "1.45rem" },
    "2xl": { "$type": "dimension", "$value": "1.9rem" },
    "3xl": { "$type": "dimension", "$value": "2.6rem" }
  },
  "weight": {
    "regular": { "$type": "number", "$value": 400 },
    "medium": { "$type": "number", "$value": 550 },
    "bold": { "$type": "number", "$value": 700 }
  }
}
