{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mosaic-media.github.io/mosaic-sdui/schema/action.schema.json",
  "title": "Action",
  "description": "A declarative behaviour envelope. Data, never code — the client interprets the kind. Each kind uses a subset of the fields.",
  "type": "object",
  "required": ["kind"],
  "properties": {
    "kind": {
      "enum": ["navigate", "back", "openUrl", "invoke", "query", "openOverlay", "closeOverlay", "playPart", "toast", "sequence"]
    },
    "screen": { "type": "string" },
    "params": { "type": "object" },
    "url": { "type": "string" },
    "mutation": { "type": "string" },
    "input": { "type": "object" },
    "query": { "type": "string" },
    "variables": { "type": "object" },
    "into": { "type": "string" },
    "surface": { "enum": ["modal", "sheet", "drawer"] },
    "node": { "$ref": "uinode.schema.json" },
    "partId": { "type": "string" },
    "nodeId": { "type": "string" },
    "message": { "type": "string" },
    "tone": { "$ref": "#/$defs/tone" },
    "actions": { "type": "array", "items": { "$ref": "#" } }
  },
  "$defs": {
    "tone": { "enum": ["neutral", "accent", "success", "warning", "danger", "info"] }
  },
  "additionalProperties": false
}
